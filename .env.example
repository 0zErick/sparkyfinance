# Sparky Finance - Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git!

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key-here

# AI Gateway (Edge Functions)
# Set this in Supabase Edge Functions environment variables, not here
# LOVABLE_API_KEY=your-ai-gateway-key

# App Configuration
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0

# Optional: For local Supabase development
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
